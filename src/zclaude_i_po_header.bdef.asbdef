managed;
strict ( 2 );

define behavior for ZClaude_I_PO_Header alias POHeader
persistent table zcld_po_header
lock master
authorization master ( global )
{
  association _Item;

  mapping for zcld_po_header corresponding
  {
    Ebeln = ebeln;
    Bukrs = bukrs;
    Bsart = bsart;
    Lifnr = lifnr;
    Bedat = bedat;
    Ekorg = ekorg;
    Ekgrp = ekgrp;
    Waers = waers;
  }
}

define behavior for ZClaude_I_PO_Item alias POItem
persistent table zclaude_po_item
lock dependent by _Header
authorization dependent by _Header
{
  association _Header;

  mapping for zclaude_po_item corresponding
  {
    Ebeln = ebeln;
    Ebelp = ebelp;
    Matnr = matnr;
    Txz01 = txz01;
    Menge = menge;
    Meins = meins;
    Netpr = netpr;
    Netwr = netwr;
    Werks = werks;
  }
}
